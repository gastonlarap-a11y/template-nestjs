# ---------------------------------------------------------------------------
# Environment template. Copy to the file matching your stage, e.g.
#   cp env/.env.example env/.env.local
# The active file is selected by APP_ENV (defaults to `local`) and validated at
# boot by the Zod schema in `env/env.schema.ts` — a bad value fails fast with a
# clear message. In Azure, supply these via App Settings / Key Vault references
# (no .env file is loaded; the platform injects them into process.env).
# ---------------------------------------------------------------------------

# ---- Deployment stage -----------------------------------------------------
# Selects env/.env.<APP_ENV>. One of: local | dev | qa | prod.
APP_ENV=local

# ---- Runtime --------------------------------------------------------------
# NODE_ENV keeps its standard meaning (development | production | test) for the
# framework and tooling — it is NOT the stage selector (that is APP_ENV).
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_PREFIX=api

# ---- Observability --------------------------------------------------------
LOG_LEVEL=debug
# Enable Azure Monitor / Application Insights by setting this (no-op if unset).
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...

# ---- API docs -------------------------------------------------------------
SWAGGER_ENABLED=true

# ---- Database (Prisma + SQL Server) --------------------------------------
# JDBC-style connection string. Matches docker-compose.yml credentials.
DATABASE_URL="sqlserver://localhost:1433;database=appdb;user=sa;password=Your_password123;encrypt=true;trustServerCertificate=true"

# ---- Authentication (dual strategy) --------------------------------------
# LOCAL mock mode: validate HS256 tokens against LOCAL_JWT_SECRET (offline RBAC).
USE_LOCAL_MOCK_AUTH=true
LOCAL_JWT_SECRET=change-me-to-a-long-random-secret-string
LOCAL_JWT_EXPIRES_IN=3600

# AZURE AD mode (set USE_LOCAL_MOCK_AUTH=false and fill these in):
# AZURE_AD_TENANT_ID=00000000-0000-0000-0000-000000000000
# AZURE_AD_AUDIENCE=api://your-api-client-id
# AZURE_AD_ISSUER=https://login.microsoftonline.com/<tenant>/v2.0
