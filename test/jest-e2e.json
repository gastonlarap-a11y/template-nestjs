{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "transformIgnorePatterns": ["/node_modules/(?!\\.pnpm/jose@|jose/)"],
  "moduleNameMapper": {
    "^@env/(.*)$": "<rootDir>/../env/$1",
    "^@app/(.*)$": "<rootDir>/../libs/$1"
  }
}
